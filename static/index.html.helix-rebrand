<script>
'use strict';
const $ = id => document.getElementById(id);
const f2 = el => parseFloat(el.value).toFixed(2);
const fv = el => parseFloat(el.value);
function syncFromRange(valId, rangeEl){const v=parseFloat(rangeEl.value);$(valId).value=v.toFixed(2);}
function syncFromNum(rangeId, numEl, min, max){let v=parseFloat(numEl.value);if(isNaN(v))return;v=Math.min(max,Math.max(min,v));numEl.value=v.toFixed(2);$(rangeId).value=v;}

function st(name){
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active',t.dataset.tab===name));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  $('tab-'+name).classList.add('active');
  
}
let _nt;
function notify(msg){const el=$('notif');el.textContent=msg;el.classList.add('show');clearTimeout(_nt);_nt=setTimeout(()=>el.classList.remove('show'),2500);}
async function p(url,body){try{await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});}catch(e){notify('Network error');}}
const _pT={};
function pDebounced(key,url,body,delay=350){clearTimeout(_pT[key]);_pT[key]=setTimeout(()=>p(url,body),delay);}
async function api(url,opts={}){const r=await fetch(url,opts);if(!r.ok)throw new Error(await r.text());return r.json();}

// ── WebSocket ─────────────────────────────────────────────────────────────────
let ws;let _wsPingInterval;
function wsConnect(){
  const proto=location.protocol==='https:'?'wss:':'ws:';
  ws=new WebSocket(`${proto}//${location.host}/ws`);
  ws.onopen=()=>{$('s-ws').textContent='Connected';$('s-ws').style.color='var(--green)';clearInterval(_wsPingInterval);_wsPingInterval=setInterval(()=>{if(ws.readyState===1)ws.send('ping');},10000);};
  ws.onmessage=e=>{
    const d=JSON.parse(e.data);
    applyStatus(d);
  };
  ws.onclose=()=>{$('ws-dot').className='err';$('s-ws').textContent='Reconnecting…';$('s-ws').style.color='var(--red)';setTimeout(wsConnect,2000);};
}
wsConnect();

function applyStatus(d){
  const _mv=$('hdr-makcu-val');if(_mv){_mv.textContent=d.makcu_connected?'OK':'N/C';_mv.className=d.makcu_connected?'ok':'err';}$('ws-dot').className=d.makcu_connected?'ok':'err';
  card('sc-recoil',d.recoil_enabled?'on':'');$('sc-recoil-v').textContent=d.recoil_enabled?'ON':'OFF';
  card('sc-flash',d.flashlight_active?'on':'');$('sc-flash-v').textContent=d.flashlight_active?'ON':'OFF';
  const hs=d.loaded_script&&d.loaded_script!=='NONE';
  card('sc-script',hs?'on':'');$('sc-script-v').textContent=d.loaded_script||'NONE';
  const cb=$('r-en');if(cb&&cb.checked!==d.recoil_enabled)cb.checked=d.recoil_enabled;
  const ms=$('s-mst');if(ms){ms.textContent=d.makcu_connected?'Connected':'Not connected';ms.style.color=d.makcu_connected?'var(--green)':'var(--red)';}
  if(hs&&!sNewScriptMode&&document.activeElement!==$('s-name-inp')){$('s-name-inp').value=d.loaded_script.split('/').pop();}
}
function card(id,state){const el=$(id);if(!el)return;el.classList.remove('on','err');if(state==='on')el.classList.add('on');if(state==='err')el.classList.add('err');}

// ── Load state ────────────────────────────────────────────────────────────────
async function loadState(){
  try{
    const d=await api('/api/state');
    const r=d.recoil||{},fl=d.flashlight||{},s=d.settings||{};
    chk('r-en',r.enabled);sel('r-tkb',r.toggle_keybind||'NONE');sel('r-ckb',r.cycle_keybind||'NONE');
    chk('r-aim',r.require_aim);chk('r-loop',r.loop_recoil);chk('r-rand',r.randomisation);chk('r-rch',r.return_crosshair);
    slid('r-sc','v-sc',r.recoil_scalar??1);slid('r-xc','v-xc',r.x_control??1);
    slid('r-yc','v-yc',r.y_control??1);slid('r-rs','v-rs',r.randomisation_strength??0.5);
    slid('r-rspd','v-rspd',r.return_speed??0.5);
    chk('fl-en',fl.enabled);sel('fl-kb',fl.keybind||'NONE');
    num('fl-ht',fl.hold_threshold_ms??50);num('fl-cd',fl.cooldown_ms??500);
    num('fl-pfmin',fl.pre_fire_min_ms??15);num('fl-pfmax',fl.pre_fire_max_ms??15);
    const games=['Manual','Arena Breakout Infinite','CS2','Gray Zone Warfare','Hunt: Showdown','Marathon','Marvel Rivals','PUBG: Battlegrounds','Valorant'];
    $('st-game').innerHTML=games.map(g=>`<option>${g}</option>`).join('');
    sel('st-game',s.game_scalar||'Manual');num('st-sens',s.game_sensitivity??1);
    $('s-srv').textContent=location.host;
    // ── Restore game directory from loaded script ─────────────────────────
    let defaultGame = '';
    if(r.loaded_script && r.loaded_script !== 'NONE' && r.loaded_script.includes('/')) {
      defaultGame = r.loaded_script.split('/')[0];
    }
    sCurrentGame = defaultGame;
    updateDirLabel(defaultGame);
    populateGameSelector(d.games||[], defaultGame);
    renderScripts([],r.loaded_script||'NONE');
    await refreshScripts(defaultGame);
    if(r.loaded_script&&r.loaded_script!=='NONE') await loadScriptContent(r.loaded_script);
    applyStatus({makcu_connected:d.makcu_connected,recoil_enabled:r.enabled,flashlight_active:fl.enabled&&r.enabled,loaded_script:r.loaded_script});
  }catch(e){console.error('loadState:',e);}
}
function chk(id,v){const el=$(id);if(el)el.checked=!!v;}
function num(id,v){const el=$(id);if(el)el.value=v;}
function sel(id,v){const el=$(id);if(!el)return;for(const o of el.options)if(o.value===v||o.text===v){o.selected=true;break;}}
function slid(sid,lid,v){const s=$(sid),l=$(lid);if(s)s.value=v;if(l)l.value=parseFloat(v).toFixed(2);}

// ── Scripts ───────────────────────────────────────────────────────────────────
let sCurrentGame = '';
let sNewScriptMode = false;  // true when New is clicked — suppresses WebSocket name overwrite
let sDir = 'saved_scripts/';

function updateDirLabel(game) {
  sDir = game ? `saved_scripts/${game}/` : 'saved_scripts/';
  const el = $('s-dir-lbl');
  if(el) el.textContent = sDir;
}

function populateGameSelector(games, current) {
  const sel = $('s-game-sel');
  sel.innerHTML = '<option value="">(root)</option>' +
    games.map(g=>`<option value="${g}">${g}</option>`).join('');
  if(current) for(const o of sel.options) if(o.value===current){o.selected=true;break;}
}

async function switchGame(game) {
  sCurrentGame = game;
  updateDirLabel(game);
  await refreshScripts(game);
}

async function refreshScripts(game) {
  try {
    const url = game ? `/api/scripts?game=${encodeURIComponent(game)}` : '/api/scripts';
    const d = await api(url);
    renderScripts(d.scripts||[], d.loaded||'NONE');
    // Update game selector with all games
    populateGameSelector(d.games||[], sCurrentGame);
  } catch(e){}
}

function renderScripts(scripts, loaded) {
  const list = $('s-list');
  if(!scripts.length){
    list.innerHTML='<div class="empty-s">No scripts<br>Save one below</div>';
    return;
  }
  list.innerHTML = scripts.map(s => {
    const fullName = sCurrentGame ? `${sCurrentGame}/${s}` : s;
    const isLoaded = loaded===fullName || loaded===s;
    return `<div class="srow2 ${isLoaded?'loaded':''}">
      <div class="sname" onclick="loadScript('${s}','${sCurrentGame}')" title="${s}">${s}</div>
      <button class="sdel" onclick="delScript('${s}','${sCurrentGame}')">✕</button>
    </div>`;
  }).join('');
}

async function loadScriptContent(fullName) {
  try {
    const parts = fullName.split('/');
    let url;
    if(parts.length>=2) url=`/api/scripts/content/${encodeURIComponent(parts[0])}/${encodeURIComponent(parts[1])}`;
    else url=`/api/scripts/content/${encodeURIComponent(fullName)}`;
    const r=await fetch(url);
    if(r.ok){
      const txt=await r.text();
      $('vec-ta').value=txt;
      
      
      $('s-name-inp').value=parts[parts.length-1];
    }
  }catch(e){}
}

async function loadScript(name, game) {
  sNewScriptMode = false;
  sNewScriptMode = false;
  let url;
  if(game) url=`/api/scripts/load/${encodeURIComponent(game)}/${encodeURIComponent(name)}`;
  else url=`/api/scripts/load/${encodeURIComponent(name)}`;
  await fetch(url,{method:'POST'});
  const fullName = game ? `${game}/${name}` : name;
  await loadScriptContent(fullName);
  await refreshScripts(sCurrentGame);
  notify(`Loaded: ${name}`);
}

async function delScript(name, game) {
  if(!confirm(`Delete "${name}"?`)) return;
  let url;
  if(game) url=`/api/scripts/${encodeURIComponent(game)}/${encodeURIComponent(name)}`;
  else url=`/api/scripts/${encodeURIComponent(name)}`;
  await fetch(url,{method:'DELETE'});
  const fullName=game?`${game}/${name}`:name;
  const currentName=$('s-name-inp').value.trim();
  if(currentName===name||currentName===fullName){$('vec-ta').value='';$('s-name-inp').value='';}
  await refreshScripts(sCurrentGame);
  notify(`Deleted: ${name}`);
}

async function saveScript() {
  sNewScriptMode = false;
  sNewScriptMode = false;
  const name=($('s-name-inp').value||'').trim();
  const content=$('vec-ta').value.trim();
  if(!name){notify('Enter a script name');return;}
  await api('/api/scripts/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,content,game:sCurrentGame||null})});
  const url=sCurrentGame?`/api/scripts/load/${encodeURIComponent(sCurrentGame)}/${encodeURIComponent(name)}`:`/api/scripts/load/${encodeURIComponent(name)}`;
  await fetch(url,{method:'POST'});
  await refreshScripts(sCurrentGame);
  
  
  notify(`Saved: ${name}`);
}

function newScript(){sNewScriptMode=true;$('vec-ta').value='';$('s-name-inp').value='';setTimeout(()=>$('s-name-inp').focus(),50);}

async function newGame() {
  const g=prompt('New game folder name:');
  if(!g||!g.trim()) return;
  // Create a placeholder so the folder exists — just refresh
  sCurrentGame=g.trim();
  const sel=$('s-game-sel');
  const opt=document.createElement('option');
  opt.value=g.trim();opt.text=g.trim();
  sel.appendChild(opt);sel.value=g.trim();
  renderScripts([],'NONE');
  notify(`Game folder: ${g} (save a script to create it)`);
}

// ── Recoil toggle ─────────────────────────────────────────────────────────────
async function toggleRecoil(){
  try{const d=await api('/api/recoil/toggle',{method:'POST'});chk('r-en',d.enabled);notify(d.enabled?'● Recoil ON':'● Recoil OFF');}
  catch(e){notify('Toggle failed');}
}
async function toggleFlashlight(){
  try{const d=await api('/api/flashlight/toggle',{method:'POST'});chk('fl-en',d.enabled);notify(d.enabled?'● Flash ON':'● Flash OFF');}
  catch(e){notify('Toggle failed');}
}

// ── Browser hotkey ────────────────────────────────────────────────────────────
let bHK=localStorage.getItem('cearum_hk')||'',capHK=false;
(function(){$('hk-el').textContent=bHK||'—';})();
function captureHK(){capHK=true;$('hk-el').textContent='press key…';$('hk-el').classList.add('cap');}
function clearHK(){bHK='';localStorage.removeItem('cearum_hk');capHK=false;$('hk-el').classList.remove('cap');$('hk-el').textContent='—';}
document.addEventListener('keydown',e=>{
  if(capHK){if(e.key==='Escape'){capHK=false;$('hk-el').classList.remove('cap');$('hk-el').textContent=bHK||'—';return;}bHK=e.key;localStorage.setItem('cearum_hk',e.key);capHK=false;$('hk-el').classList.remove('cap');$('hk-el').textContent=e.key;e.preventDefault();return;}
  const tag=document.activeElement.tagName;if(tag==='INPUT'||tag==='TEXTAREA'||tag==='SELECT')return;
  if(bHK&&e.key===bHK){toggleRecoil();e.preventDefault();}
});

// ── Tools ──────────────────────────────────────────────────────────────────────
function selTool(id,el){
  document.querySelectorAll('.tool-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tools-sb-item').forEach(i=>i.classList.remove('active'));
  const panel=document.getElementById('tool-'+id);
  if(panel)panel.classList.add('active');
  if(el)el.classList.add('active');
}
function runCalc(){
  const fps=parseFloat($('calc-fps').value);
  const frm=parseInt($('calc-frm').value);
  const res=$('calc-result');
  if(!fps||!frm||fps<=0||frm<=0){res.style.display='none';return;}
  const ms=(1000/fps)*frm;
  const rpm=60000/ms;
  $('calc-ms').textContent=Math.round(ms*100)/100+' ms';
  $('calc-rpm').textContent=Math.round(rpm*10)/10+' RPM';
  res.style.display='grid';
}

// ═══════════════════════════════════════════════════════════════════════════
//  VECTOR EDITOR



loadState();

// ── MAKCU poll — independent of WebSocket, catches hardware disconnects ──────
async function pollMakcu(){
  try{
    const d=await(await fetch('/api/streamdeck')).json();
    applyStatus({makcu_connected:d.makcu,recoil_enabled:d.recoil,flashlight_active:d.flashlight,loaded_script:d.script});
  }catch(e){}
}
setInterval(pollMakcu,7000);

// ── Wake Lock — keep screen on while page is open ─────────────────────────────
(async function initWakeLock(){
  if(!('wakeLock' in navigator)) return; // not supported (older browsers)
  let lock = null;

  async function acquire(){
    try{
      lock = await navigator.wakeLock.request('screen');
      lock.addEventListener('release', ()=>{ lock=null; });
    }catch(e){
      // User denied or browser blocked — silently ignore
    }
  }

  // Reacquire when tab becomes visible again (e.g. switching back from another app)
  document.addEventListener('visibilitychange', ()=>{
    if(document.visibilityState==='visible' && !lock) acquire();
  });

  acquire();
})();
</script>
